{
  "name": "@qontinui/workflow-utils",
  "version": "0.1.0",
  "description": "Pure utility functions for the Qontinui workflow system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && test -s dist/index.d.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qontinui/shared-types": "file:../qontinui-schemas/ts"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "author": "Joshua Spinak",
  "license": "MIT"
}
